generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HOST
  ATTENDEE
}

enum EventStatus {
  DRAFT
  LIVE
  PRIVATE
  CANCELLED
  ENDED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  WAITLISTED
  CANCELLED
}

enum SharePermission {
  VIEW
  EDIT
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  image     String?
  role      Role     @default(ATTENDEE)
  company   String?
  position  String?
  bio           String?
  organizerLogo String?
  bannerUrl     String?
  themePreset   String?  @default("teal")
  instagram     String?
  linkedin      String?
  website       String?
  twitter       String?
  termsAcceptedAt DateTime?
  privacyAcceptedAt DateTime?
  hostResponsibilityAcceptedAt DateTime?
  policyVersion String?
  signupIp String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hostedEvents  Event[]      @relation("HostedEvents")
  rsvps         RSVP[]
  sharedEvents  EventShare[] @relation("SharedWith")
  accounts      Account[]
  sessions      Session[]
  deletionRequests DeletionRequest[]
  savedEvents   SavedEvent[]
  following     OrganizerFollow[] @relation("Follower")
  followers     OrganizerFollow[] @relation("Organizer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id                   String          @id @default(cuid())
  title                String
  slug                 String          @unique
  description          String?
  bannerImage          String?
  hostId               String
  status               EventStatus     @default(DRAFT)
  visibility           EventVisibility @default(PUBLIC)
  date                 DateTime
  endDate              DateTime?
  location             String?
  address              String?
  isOnline             Boolean         @default(false)
  onlineLink           String?
  maxAttendees         Int?
  ageGate              Int             @default(0)
  parkingAvailable     Boolean         @default(false)
  parkingNotes         String?
  thingsToKnow         String?
  requiresCertification Boolean        @default(false)
  certificationNote    String?
  category             String?
  tags                 String?
  customQuestions      String?
  faqs                 String?
  speakers             String?
  agenda               String?
  promoCodes           String?
  emailInviteList      String?
  confirmationMessage  String?
  dressCode            String?
  eventTheme           String?
  maxTicketsPerPerson  Int?
  pageViews            Int             @default(0)
  publishedAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  host    User         @relation("HostedEvents", fields: [hostId], references: [id])
  rsvps   RSVP[]
  tickets Ticket[]
  shares  EventShare[]
  pageViews_ EventPageView[]
  savedBy SavedEvent[]
}

model RSVP {
  id               String     @id @default(cuid())
  eventId          String
  userId           String?
  guestEmail       String
  guestName        String
  storeName        String?
  storeAddress     String?
  brand            String?
  position         String?
  certificationUrl String?
  status           RSVPStatus @default(PENDING)
  checkedIn        Boolean    @default(false)
  checkedInAt      DateTime?
  answers          String?
  createdAt        DateTime   @default(now())

  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User?  @relation(fields: [userId], references: [id])
}

model Ticket {
  id           String   @id @default(cuid())
  eventId      String
  name         String   @default("General Admission")
  description  String?
  price        Float    @default(0)
  isFree       Boolean  @default(true)
  quantity     Int?
  quantitySold Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventShare {
  id             String          @id @default(cuid())
  eventId        String
  sharedWithUserId String
  permission     SharePermission @default(VIEW)
  createdAt      DateTime        @default(now())

  event        Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sharedWith   User  @relation("SharedWith", fields: [sharedWithUserId], references: [id])

  @@unique([eventId, sharedWithUserId])
}

model DeletionRequest {
  id        String   @id @default(cuid())
  userId    String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EventPageView {
  id        String   @id @default(cuid())
  eventId   String
  ipHash    String?
  referer   String?
  path      String?
  utmSource String?
  utmMedium String?
  utmCampaign String?
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("text")
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model Announcement {
  id        String   @id @default(cuid())
  message   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  enabled     Boolean  @default(false)
  scope       String   @default("global")
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model SiteAsset {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  type        String   @default("image")
  url         String
  alt         String?
  metadata    String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model AdSlot {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  headline    String?
  body        String?
  ctaLabel    String?
  ctaHref     String?
  imageUrl    String?
  active      Boolean  @default(false)
  priority    Int      @default(0)
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model ManagedPageSection {
  id          String   @id @default(cuid())
  pageKey     String
  sectionKey  String
  label       String
  variant     String   @default("default")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  config      String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@unique([pageKey, sectionKey])
}

model AdminChangeLog {
  id             String   @id @default(cuid())
  actorUserId    String
  targetType     String
  targetId       String
  action         String
  summary        String
  payloadBefore  String?
  payloadAfter   String?
  createdAt      DateTime @default(now())
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model OrganizerFollow {
  id          String   @id @default(cuid())
  followerId  String
  organizerId String
  createdAt   DateTime @default(now())

  follower   User @relation("Follower",   fields: [followerId],  references: [id], onDelete: Cascade)
  organizer  User @relation("Organizer",  fields: [organizerId], references: [id], onDelete: Cascade)

  @@unique([followerId, organizerId])
}

model ContentReport {
  id         String   @id @default(cuid())
  reporterId String?
  targetType String
  targetId   String
  reason     String
  details    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}
